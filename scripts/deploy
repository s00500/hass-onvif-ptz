#!/usr/bin/env bash
set -euo pipefail

HA_HOST="root@homeserver.bachi.io"
HA_PORT="22"
REMOTE_PATH="/config/custom_components/onvif_ptz/"
LOCAL_PATH="$(cd "$(dirname "$0")/.." && pwd)/custom_components/onvif_ptz/"

SSH_OPTS="-p ${HA_PORT}"


ssh ${SSH_OPTS} "${HA_HOST}" "apk add rsync"
echo "==> Syncing component to ${HA_HOST}:${REMOTE_PATH}"
rsync -avz --delete -e "ssh ${SSH_OPTS}" "${LOCAL_PATH}" "${HA_HOST}:${REMOTE_PATH}"

echo "==> Restarting Home Assistant core..."
ssh ${SSH_OPTS} "${HA_HOST}" "ha core restart"

echo "==> Done. HA is restarting."
